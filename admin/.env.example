# 관리자 프론트엔드 환경 설정

# API 서버 URL
REACT_APP_API_URL=http://localhost:3001

# 애플리케이션 환경 (development, production)
REACT_APP_ENV=development

# 디버그 모드 (true/false)
REACT_APP_DEBUG=true

# 페이지네이션 기본 설정
REACT_APP_DEFAULT_PAGE_SIZE=20

# 세션 타임아웃 (분)
REACT_APP_SESSION_TIMEOUT=30

# 새로고침 간격 (초) - 실시간 업데이트용
REACT_APP_REFRESH_INTERVAL=30

# 파일 업로드 최대 크기 (MB)
REACT_APP_MAX_FILE_SIZE=10

# 지원 파일 형식 (쉼표로 구분)
REACT_APP_SUPPORTED_FILE_TYPES=.jpg,.jpeg,.png,.gif,.pdf,.doc,.docx

# 로깅 레벨 (error, warn, info, debug)
REACT_APP_LOG_LEVEL=info

# 구글 애널리틱스 ID (선택사항)
# REACT_APP_GA_ID=

# 센트리 DSN (에러 추적, 선택사항)
# REACT_APP_SENTRY_DSN=