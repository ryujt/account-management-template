# Environment Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_database_password
DB_NAME=account_management

# JWT Configuration
JWT_ACCESS_SECRET=your_super_secure_jwt_access_secret_key_here
JWT_REFRESH_SECRET=your_super_secure_jwt_refresh_secret_key_here
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_ISSUER=account-management

# Session/Cookie Configuration
SESSION_COOKIE_MAX_AGE=604800000
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax
REFRESH_TOKEN_EXPIRATION=604800000

# CORS Configuration
CORS_ORIGINS=http://localhost:3001,http://localhost:3002

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Email Configuration (Optional - for email verification and password reset)
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=noreply@yourdomain.com

# Google OAuth Configuration (Optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=/auth/oauth/google/callback

# Admin Bootstrap (Optional - for initial admin setup)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_TEMP_PASSWORD=TempAdmin123!

# Security Configuration
BCRYPT_ROUNDS=12
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# Token Expiration (in milliseconds)
EMAIL_VERIFICATION_EXPIRATION=86400000
PASSWORD_RESET_EXPIRATION=3600000

# Application Configuration
APP_NAME="Account Management API"
APP_VERSION=1.0.0
APP_URL=http://localhost:3000

# Debug Configuration (Development only)
DEBUG=false
LOG_LEVEL=info

# Database Pool Configuration (Advanced)
DB_CONNECTION_LIMIT=10
DB_ACQUIRE_TIMEOUT=60000
DB_TIMEOUT=60000

# Security Headers (Production)
ENABLE_HELMET=true
ENABLE_CORS=true

# Feature Flags
ENABLE_REGISTRATION=true
ENABLE_OAUTH=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_PASSWORD_RESET=true

# Monitoring (Optional)
ENABLE_REQUEST_LOGGING=true
ENABLE_PERFORMANCE_MONITORING=false

# File Upload (Future feature)
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif

# Cache Configuration (Future feature)
REDIS_URL=redis://localhost:6379
ENABLE_CACHING=false

# Notification Configuration (Future feature)
ENABLE_PUSH_NOTIFICATIONS=false
PUSH_NOTIFICATION_KEY=

# Backup Configuration (Future feature)
BACKUP_ENABLED=false
BACKUP_FREQUENCY=daily
BACKUP_RETENTION_DAYS=30

# API Configuration
API_PREFIX=/api
API_VERSION=v1
MAX_REQUEST_SIZE=10mb

# Health Check Configuration
HEALTH_CHECK_INTERVAL=30000
HEALTH_CHECK_TIMEOUT=5000

# Cleanup Configuration
CLEANUP_INTERVAL=3600000
SESSION_CLEANUP_ENABLED=true
TOKEN_CLEANUP_ENABLED=true